{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BetterWheel",
  "version": "0.1.0",
  "identifier": "it.gibelli.betterwheel",
  "build": {
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3MjJFNzMyQUZENzEzMEMKUldRTUU5ZXZNdWNpcDZQd1MvLzdoTWRBZUxQbkl4NTZCRmNyTHBSOVNOcWNCbXBKTm9rRVpzanUK",
      "endpoints": [
        "https://github.com/betterwheel/betterwheel/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "BetterWheel",
        "width": 1200,
        "height": 820,
        "minWidth": 820,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Finance",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
