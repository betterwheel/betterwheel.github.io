# TheWheel configuration — copy to `config.toml` and edit.
# Every field is optional; anything omitted uses the default shown here.

[connection]
host = "127.0.0.1"
mode = "paper"            # "paper" or "live"
paper_port = 4002         # IB Gateway paper  (full TWS paper = 7497)
live_port  = 4001         # IB Gateway live   (full TWS live  = 7496)
client_id  = 100          # distinct id per concurrent API client
# account  = "DU1234567"  # paper accounts start with "DU"; discovered if omitted
market_data = "delayed"   # realtime | frozen | delayed | delayed_frozen
                          # realtime needs an OPRA subscription; delayed is free
reconnect_secs = 15       # retry connecting every N s while offline (0 = off)

[engine]                  # wheel tuning — common r/thetagang norms
# Tip: target_delta and take_profit_pct are also tunable live in the app's
# Settings tab (as "win rate" and "take-profit %"); changes there are saved to
# the local db and override these defaults. Adjusting win rate re-centers the
# delta band below around 1 − win.
target_delta = 0.30       # ideal short-option delta (≈ 1 − win probability)
min_delta = 0.16          # acceptable entry delta band
max_delta = 0.35
min_dte = 25              # days-to-expiration band for entries
max_dte = 45
take_profit_pct = 0.50    # buy-to-close at 50% of max premium
roll_delta = 0.50         # defend a short once its delta exceeds this
roll_dte = 21             # also consider rolling an ITM short under this DTE
min_annualized_yield = 0.20
min_open_interest = 100   # liquidity floor
min_premium = 0.05        # ignore dust
risk_free_rate = 0.04     # used by the Black-Scholes delta fallback
cc_min_pct_above_basis = 0.0  # covered-call strike must sit this far above basis
hedge_pct_below = 0.05    # Hedged Wheel: protective put at most this far below short (caps width)
hedge_min_credit = 0.10   # Hedged Wheel: skip put spreads with net credit below this

[guardrails]
max_total_deployed = 50000.0   # hard ceiling on TOTAL short-put collateral (open positions + new entry)
max_contracts_per_order = 10
require_live_confirmation = true  # in live mode, type LIVE (press `L`) to unlock transmits each session
read_only = false                 # true disables all order transmits (incl. auto profit-close / roll-open)

# -----------------------------------------------------------------------------
# 0DTE / short-dated index structures (the "0DTE" tab — a 2x2 grid of slots).
# Each [[zerodte.strategy]] is a named, parameterized structure; `slots` picks
# which roster entries (by 0-based index) the four quadrants display. Omit the
# whole section to use the four seeded defaults below. SPX is a cash-settled
# index — verify your account can trade it (the app probes tradability).
#
# kind: IronCondor | PutCreditSpread | CallCreditSpread | BrokenWingButterfly
#       | IronFly | ShortStrangle (naked — needs allow_naked + a naked tier)
# Management defaults follow the thread: take profit at 25-50%, and "the wings
# are the stop" (stop_loss_mult = 0) except on the directional spread.
# automate = false keeps every slot preview-only until you opt it in per-slot.

[zerodte]
slots = [0, 1, 2, 3]      # quadrant -> roster index (top-left, top-right, …)

[[zerodte.strategy]]
name = "Iron Condor"
kind = "IronCondor"
underlying = "SPX"
dte = 0
short_delta = 0.13        # put-side short delta
call_delta = 0.13         # call-side short delta (0 = reuse short_delta)
wing_points = 25.0        # protective wing width, in index points
delta_tol = 0.08          # acceptable band around the target delta
min_credit = 0.80         # skip if net credit/share is below this
max_risk = 3500.0         # size so the defined max loss stays within this ($) — SPX wings are wide
entry_minutes_after_open = 45
profit_target_pct = 0.40  # buy-to-close at 40% of the credit
stop_loss_mult = 0.0      # 0 = no active stop — the wings cap the loss (recommended);
                          # >0 = close once the loss reaches this multiple of the
                          # credit (active: polls live data, so needs a subscription)
# time_stop_hhmm = "15:30"  # optional active close at this ET time (cancels the
                            # standing profit-close, exits at a marketable limit)
meic_interval_min = 0     # >0 repeats entries every N min (MEIC mode)
automate = false          # per-slot opt-in for live auto-trading
allow_naked = false

[[zerodte.strategy]]
name = "Put Credit Spread"
kind = "PutCreditSpread"
dte = 1
short_delta = 0.11
wing_points = 10.0
min_credit = 0.30
max_risk = 1500.0
entry_minutes_after_open = 45
profit_target_pct = 0.40
stop_loss_mult = 1.2      # active: close once the loss reaches 1.2x the credit (120% SL)

[[zerodte.strategy]]
name = "Broken-Wing Fly"
kind = "BrokenWingButterfly"
dte = 0
short_delta = 0.32        # body (2 short puts) — near the money so the fly nets a credit
wing_points = 10.0        # narrow (upper) wing; lower wing is 3x this (skip-strike)
min_credit = 0.10
max_risk = 2000.0
entry_minutes_after_open = 30
profit_target_pct = 0.50

[[zerodte.strategy]]
name = "Iron Fly"
kind = "IronFly"
dte = 0
wing_points = 30.0
min_credit = 2.00
max_risk = 2500.0
entry_minutes_after_open = 30
profit_target_pct = 0.25
